{{> layout/header}}
<h2>회원가입</h2>
<form action="/join" method="post">
    <div>
        <label>아이디</label>
        <input type="text" name="username" id="username" required>
        <button type="button" onclick="checkUsername()">중복 확인</button>
        <span id="check-msg"></span>
    </div>
    <div>
        <label>비밀번호</label>
        <input type="password" name="password" required>
    </div>
    <div>
        <label>이메일</label>
        <input type="email" name="email" required>
    </div>
    <button type="submit">가입하기</button>
</form>
<p><a href="/login-form">이미 계정이 있으신가요? 로그인</a></p>

<script>
    function checkUsername() {
        var username = document.getElementById('username').value;
        if (!username) {
            document.getElementById('check-msg').textContent = '아이디를 입력하세요.';
            return;
        }
        fetch('/api/users/check?username=' + encodeURIComponent(username))
            .then(function(res) { return res.json(); })
            .then(function(json) {
                if (json.data) {
                    document.getElementById('check-msg').textContent = '이미 사용 중인 아이디입니다.';
                } else {
                    document.getElementById('check-msg').textContent = '사용 가능한 아이디입니다.';
                }
            });
    }
</script>
{{> layout/footer}}
