{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/save-plan-report.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/git-commit.sh create-flag"
          }
        ]
      },
      {
        "matcher": "Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-agent-log.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/git-commit.sh commit"
          }
        ]
      }
    ]
  }
}
